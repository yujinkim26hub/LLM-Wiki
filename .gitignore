# Source files: keep the folder structure and any markdown (index/landing) pages
# tracked so every source folder is browsable on the published site.
#
# Papers are open-access and are published in full — their PDFs ARE committed and
# served on the site (see 00-Sources/papers/). Large/unpublished binaries in
# books/images/data stay out of git, but their folders remain browsable via the
# index.md landing page each one carries.
00-Sources/books/**
00-Sources/images/**
00-Sources/data/**
00-Sources/articles/*.pdf
# ...but always keep folder structure, .gitkeep markers, and markdown pages
!00-Sources/**/
!00-Sources/**/.gitkeep
!00-Sources/**/*.md

# Quartz: track config + source, but not node_modules / build output / cache
.quartz/node_modules/
.quartz/public/
.quartz-cache/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Obsidian (per-user UI state)
.obsidian/

# Claude Code per-user / per-project state
.claude/

# Partial downloads, temp, editor backups
*.crdownload
*.tmp
*.part
*.swp
*.swo
*~
~$*

# Node
node_modules/
